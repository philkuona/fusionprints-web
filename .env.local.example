# Backend API base URL
# Dev: http://localhost:3000 (Fastify backend)
# Prod: https://api.fusionprints.co.zw
NEXT_PUBLIC_API_URL=http://localhost:3000

# Payonify publishable key for the embedded checkout Drop-In.
# Must pair with the backend's PAYONIFY_SECRET_KEY (same Payonify account).
NEXT_PUBLIC_PAYONIFY_PUBLISHABLE_KEY=

# Note: cloud-import options (Google Photos, Dropbox) are toggled by BACKEND env
# vars now (GOOGLE_PHOTOS_IMPORT_ENABLED, DROPBOX_APP_KEY) and surfaced at runtime
# via /web/api/imports/config — no frontend rebuild needed.
